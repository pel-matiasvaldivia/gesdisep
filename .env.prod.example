# ── GESDISEP · variables de producción (docker-compose.prod.yml) ──
# Copiar como .env en el VPS y completar. NO commitear el .env real.

# Imágenes publicadas por CI en GitHub Container Registry.
# Cambiá el tag (:main, :sha-xxxx, :v1.0.0) según lo que quieras desplegar.
API_IMAGE=ghcr.io/pel-matiasvaldivia/gesdisep-api:main
WEB_IMAGE=ghcr.io/pel-matiasvaldivia/gesdisep-web:main

# Base de datos (interna).
POSTGRES_USER=gesdisep
POSTGRES_PASSWORD=cambiar-por-una-clave-fuerte
POSTGRES_DB=gesdisep

# Secretos de la API (usar valores largos y aleatorios).
JWT_SECRET=cambiar-secreto-jwt
JWT_EXPIRES_IN=8h
CREDENCIAL_QR_SECRET=cambiar-secreto-qr

# URL pública que resuelve NPM (la que va en el QR de las credenciales).
PUBLIC_VERIFY_URL=https://registro.tu-dominio.gob.ar/verificar

# Puerto/bind del host donde NPM proxea la web.
# 127.0.0.1 = solo accesible localmente (recomendado si NPM corre en el host).
# Si NPM corre en Docker, usá el override de red (ver docker-compose.prod.yml)
# o poné WEB_BIND=0.0.0.0 y protegé el puerto con firewall.
WEB_BIND=127.0.0.1
WEB_PORT=8080

# Sembrar usuarios por rol en el PRIMER arranque; luego poné false.
SEED_ON_START=true

# Modo de los adaptadores de organismos (real|stub).
ADAPTER_RENAPER_MODE=stub
ADAPTER_AFIP_MODE=stub
ADAPTER_ATM_MODE=stub
ADAPTER_DPJ_MODE=stub
ADAPTER_REINCIDENCIA_MODE=stub
