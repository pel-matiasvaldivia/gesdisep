{
  "name": "gesdisep",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestión del Registro Provincial de Prestadores de Seguridad Privada (Mendoza - Ley 9578 / Decreto 264/2025)",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter ./apps/* dev",
    "build": "pnpm -r build",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "pnpm --filter @gesdisep/api prisma:migrate",
    "db:seed": "pnpm --filter @gesdisep/api prisma:seed",
    "api:dev": "pnpm --filter @gesdisep/api dev",
    "web:dev": "pnpm --filter @gesdisep/web dev"
  },
  "engines": {
    "node": ">=20"
  }
}
