# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL="postgresql://gesdisep:gesdisep@localhost:5432/gesdisep?schema=public"

# ── Redis (colas / caché) ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── API ───────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET="cambiar-en-produccion-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="8h"
# Secreto para firmar el token del QR de las credenciales
CREDENCIAL_QR_SECRET="cambiar-en-produccion-qr"
# URL pública para armar el enlace del QR
PUBLIC_VERIFY_URL="http://localhost:3000/verificar"
# Carpeta donde se guardan los documentos digitalizados (default: apps/api/storage)
STORAGE_DIR=""

# ── Web ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── Integraciones con organismos ─────────────────────────────
# Modo de cada adaptador: "real" (llama a la API del organismo) o "stub"
# (respuesta simulada determinística para desarrollo).
ADAPTER_RENAPER_MODE=stub
ADAPTER_AFIP_MODE=stub
ADAPTER_ATM_MODE=stub
ADAPTER_DPJ_MODE=stub
ADAPTER_REINCIDENCIA_MODE=stub

# Endpoints reales (se usan cuando el modo es "real")
RENAPER_BASE_URL=""
RENAPER_API_KEY=""
AFIP_BASE_URL=""
AFIP_API_KEY=""
